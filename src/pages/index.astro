---
import PortfolioLayout from '../layouts/PortfolioLayout.astro';
import ScrollProgress from '../components/ScrollProgress.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import FootnoteTooltip from '../components/FootnoteTooltip.astro';
import FixedCTA from '../components/FixedCTA.astro';
import BioSection from '../components/portfolio/BioSection.astro';
import ContactSection from '../components/portfolio/ContactSection.astro';
import CareerSection from '../components/portfolio/CareerSection.astro';
import ExperienceSection from '../components/portfolio/ExperienceSection.astro';
import SkillsSection from '../components/portfolio/SkillsSection.astro';
import EducationSection from '../components/portfolio/EducationSection.astro';
import PortfolioCTA from '../components/portfolio/PortfolioCTA.astro';
---

<PortfolioLayout
  title="송재욱"
  description="안녕하세요, 프론트엔드 개발자 송재욱입니다."
>
  <ScrollProgress />
  <ThemeToggle />

  <main>
    <BioSection />
    <ContactSection />
    <CareerSection />
    <ExperienceSection />
    <SkillsSection />
    <EducationSection />
    <PortfolioCTA />
  </main>

  <FixedCTA />
  <FootnoteTooltip />
</PortfolioLayout>

<style>
  main {
    max-width: 680px;
    margin: 0 auto;
    padding: 3.5rem 1.5rem 5rem;
  }
</style>
