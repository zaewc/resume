---
import ChipLink from '../ChipLink.astro';
import DateLabel from '../DateLabel.astro';
import Fn from '../Fn.astro';
---

<section class="mb-10">
  <h2 class="section-title">Career</h2>

  <!-- мҠӨнғҖнҠём—…нҢҖ -->
  <div class="org-block">
    <div class="org-header">
      <h3 class="org-name">мҠӨнғҖнҠём—…нҢҖ</h3>
    </div>
    <p class="org-role">Frontend Developer</p>

    <!-- е…үнғҲнҺҳ -->
    <div class="proj-block">
      <div class="proj-header">
        <span class="proj-name">
          е…үнғҲнҺҳ н”Ңлһ«нҸј
          <ChipLink
            href="https://github.com/School-of-Company/Gwangju-talent-festival-Client"
            icon="bi-github"
            label="GitHub"
          />
        </span>
        <DateLabel date="2025. 02. ~ 2025. 10." />
      </div>
      <p class="desc">
        көҗмңЎмІӯкіј кҙ‘мЈјкі л“ұн•ҷмғқмқҳнҡҢк°Җ мЈјлҸ„н•ҳлҠ” мҳӨл””м…ҳ н”„лЎңк·ёлһЁ 'кҙ‘нғҲнҺҳ'мқҳ кіөмӢқ н”Ңлһ«нҸј.<Fn
          note="кё°мЎҙ 23~24л…„ мҳҲл§Ө м„ңл№„мҠӨлҠ” көҗмңЎмІӯмқҙ SI м—…мІҙм—җ мң„нғҒн•ҙ мҡҙмҳҒн–ҲмңјлӮҳ, кё°лҠҘм Ғ мҷ„м„ұлҸ„мҷҖ UX мёЎл©ҙм—җм„ң л¶ҲнҺёмқҙ мһҲм—ҲмқҢ"
        />
        мҳҲл§Ө кё°лҠҘм—җ к·ём№ҳм§Җ м•Ҡкі  н”„лЎңк·ёлһЁ мҶҢк°ң, мҠ¬лЎңкұҙ кіөлӘЁ, м°ём—¬ мӢ мІӯ, мӢӨмӢңк°„ нҲ¬н‘ңк№Ңм§Җ м ңкіөн•ҳлҠ” н”Ңлһ«нҸјмңјлЎң
        нҷ•мһҘ к°ңл°ң.
        <strong>1,000л§Ң+мӣҗмқҳ мҷёмЈј мһ…м°° л№„мҡ©мқ„ м Ҳк°җ.</strong>
        н–үмӮ¬ лӢ№мқј <strong>DAU 3,000+лӘ…</strong><Fn
          note="Vercel кё°мӨҖ лҲ„м Ғ нҠёлһҳн”Ҫ 7.3л§Ң+, GA кё°мӨҖ мқҙлІӨнҠё 5л§Ң+кұҙ"
        />
      </p>

      <ul class="bul-list">
        <li>мһҗмІҙ Auth лЎңм§Ғ кө¬нҳ„</li>
        <li>
          мӢӨмӢңк°„ мўҢм„қ мҳҲл§Ө кё°лҠҘ(SSE) кө¬нҳ„, кі„м •лі„ мҳҲл§Ө м—¬л¶Җм—җ л”°лқј лҸҷм Ғ лқјмҡ°нҢ… м Ғмҡ©
          <ul class="sub-bul-list">
            <li>
              useMemo мқҳмЎҙм„ұм—җ л¶ҲліҖ к°қмІҙ queryClientлҘј л„Јм–ҙ UIк°Җ к°ұмӢ лҗҳм§Җ м•ҠлҚҳ<Fn
                note="queryClient.getQueryData()лҠ” нҳём¶ң мӢңм җмқҳ мәҗмӢңл§Ң л°ҳнҷҳн•ҳлҠ” мқјнҡҢм„ұ мЎ°нҡҢлқј reactive мӢңмҠӨн…ңкіј м—°кІ°лҗҳм§Җ м•ҠмқҢ"
              /> л¬ём ңлҘј, useQueriesлЎң м „нҷҳн•ҙ
              <strong>SSE мҲҳмӢ  мҰүмӢң мўҢм„қ м җмң мңЁ мӢӨмӢңк°„ л°ҳмҳҒ</strong>
            </li>
          </ul>
        </li>
        <li>
          next.js Metadata APIлЎң OG/keywords м„Өм •, next-sitemap prebuild мһҗлҸҷнҷ” вҶ’
          <strong>мЈјмҡ” кІҖмғүм—”м§„ мөңмғҒлӢЁ л…ём¶ң</strong>
        </li>
        <li>
          SSG + м„№м…ҳлі„ Lazy Loading, нһҲм–ҙлЎң м„№м…ҳ priority preload вҶ’
          <strong>Lighthouse FCPВ·LCPВ·SI к°Ғ м•Ҫ 60% к°ңм„ </strong><Fn
            note="FCP 0.8sвҶ’0.3s / LCP 2.1sвҶ’0.7s / SI 1.1sвҶ’0.6s"
          />
        </li>
      </ul>
    </div>

    <!-- EXPO -->
    <div class="proj-block">
      <div class="proj-header">
        <span class="proj-name">
          EXPO
          <ChipLink
            href="https://github.com/School-of-Company/Expo-Client"
            icon="bi-github"
            label="GitHub"
          />
        </span>
        <DateLabel date="2024. 10. ~ нҳ„мһ¬" />
      </div>
      <p class="desc">
        кҙ‘мЈјкҙ‘м—ӯмӢңкөҗмңЎмІӯ мҲҳмЈј н”„лЎңм қнҠё. мӮ¬м „ мӢ мІӯВ·QR нҳ„мһҘ мқёмҰқВ·л§ҢмЎұлҸ„ мЎ°мӮ¬В·Excel мһҗлҸҷ м •лҰ¬лҘј нҶөн•©
        м ңкіө.
        <strong>кё°мЎҙ мҷёмЈј мһ…м°° л№„мҡ© 2,000л§Ң+мӣҗ м Ҳк°җ, 3л§Ң+лӘ… мҡҙмҳҒ.</strong><Fn
          note="AIВ·SW мІҙн—ҳ м¶•м „кіј лҜёлһҳкөҗмңЎл°•лһҢнҡҢлҘј нҸ¬н•Ён•ң мҲҳм№ҳ"
        />
      </p>
      <ul class="bul-list">
        <li>
          лҸҷм Ғ нҸј мҠӨнӮӨл§Ҳ/нғҖмһ… кі лҸ„нҷ” л°Ҹ API payload/лҚ°мқҙн„° ліҖнҷҳ лЎңм§Ғ кө¬нҳ„
          <ul class="sub-bul-list">
            <li>
              л ҢлҚ”л§Ғ мӢңм җл§ҲлӢӨ л°ҳліө мӢӨн–үлҗҳлҚҳ JSON.parse()лҘј Zod Schema кё°л°ҳ Wrapper LayerлЎң мқҙлҸҷ вҶ’
              <strong>JSON.parse() 1нҡҢлЎң к°җмҶҢ, White Screen of Death мң„н—ҳ м°ЁлӢЁ</strong><Fn
                note="мһҳлӘ»лҗң JSON нҳ•мӢқ м§„мһ… мӢң м „мІҙ нҸјмқҙ л ҢлҚ”л§Ғлҗҳм§Җ м•ҠлҠ” л¬ём ңк°Җ мһҲм—ҲмқҢ. ZodлЎң мҲҳмӢ  м§Ғнӣ„ кІҖмҰқн•ҳм—¬ UI м»ҙнҸ¬л„ҢнҠё лӮҙ лҹ°нғҖмһ„ нғҖмһ… к°Җл“ңлҘј мҷ„м „ м ңкұ°"
              />
            </li>
            <li>м§Ҳл¬ё м ңлӘ© кё°л°ҳ slugify ID вҶ’ UUID кё°л°ҳмңјлЎң көҗмІҙн•ҳм—¬ лҚ°мқҙн„° л¬ҙкІ°м„ұ нҷ•ліҙ</li>
          </ul>
        </li>
        <li>мҡ”мІӯ лҚ°мқҙн„° кё°л°ҳ QR м •ліҙ мЈјмһ…, нҶ нҒ° мң л¬ҙ л“ұ нҳ„мһҘ мҳҲмҷё мјҖмқҙмҠӨ лҢҖмқ‘</li>
      </ul>
    </div>

    <!-- мӢңлҜјнҷ”нҸҗ кҙ‘мӮ° -->
    <div class="proj-block">
      <div class="proj-header">
        <span class="proj-name">
          мӢңлҜјнҷ”нҸҗ кҙ‘мӮ°
          <ChipLink
            href="https://github.com/School-of-Company/Gwangsan-Crossplatform"
            icon="bi-github"
            label="GitHub"
          />
        </span>
        <DateLabel date="2025. 04. ~ нҳ„мһ¬" />
      </div>
      <p class="desc">
        кҙ‘мЈјкҙ‘м—ӯмӢң кҙ‘мӮ°кө¬ мҲҳмЈј н”„лЎңм қнҠё. м§Җм—ӯ лӮҙ к°ҖмғҒ нҷ”нҸҗ 'кҙ‘мӮ°'мқ„ нҷңмҡ©н•ң м„ңл№„мҠӨВ·л¬јн’Ҳ кұ°лһҳ н”Ңлһ«нҸј.
        iOS нҢҢнҠё к°ңл°ңмһҗк°Җ к°‘мһ‘мҠӨлҹҪкІҢ мқҙнғҲн•ҳлҠ” мғҒнҷ©м—җм„ң<Fn
          note="лӢҙлӢ№мқҖ м–ҙл“ңлҜј мӣ№ к°ңл°ңмқҙм—ҲмңјлӮҳ, мӣҗнҷңн•ң м§„н–үкіј нҒҙлқјмқҙм–ёнҠёмҷҖмқҳ мӢ лў° мң м§ҖлҘј мң„н•ҙ мһҗл°ңм ҒмңјлЎң React Native нҲ¬мһ…"
        />
        <strong>React NativeлЎң кіөл°ұмқ„ л©”мҡ°кі  App Store лҰҙлҰ¬мҰҲк№Ңм§Җ м§„н–ү.</strong>
      </p>
      <ul class="bul-list">
        <li>лӘЁл°”мқјм•ұ: кұ°лһҳ кІҢмӢңкёҖ л°Ҹ мұ„нҢ…мңјлЎң л¬јкұҙ/м„ңл№„мҠӨлҘј көҗнҷҳн•  мҲҳ мһҲлҠ” MVP н”ҢлЎңмҡ° кө¬нҳ„</li>
        <li>
          мӣ№(м–ҙл“ңлҜј): к°Җмһ… мҠ№мқё, мӢ кі  мІҳлҰ¬, 'кҙ‘мӮ°' м§ҖкёүВ·нҡҢмҲҳ мҡҙмҳҒ кё°лҠҘ к°ңл°ң л°Ҹ мҡҙмҳҒ
          <ul class="sub-bul-list">
            <li>
              Zustand Persistent Queue лҸ„мһ… + лӮҷкҙҖм Ғ м—…лҚ°мқҙнҠё вҶ’
              <strong>WebSocket л©”мӢңм§Җ мң мӢӨлҘ  1% мқҙлӮҙлЎң к°җмҶҢ</strong><Fn
                note="кё°мЎҙм—җлҠ” connectionStateл§Ң нҷ•мқё нӣ„ м „мҶЎн•ҳм—¬ л„ӨнҠёмӣҢнҒ¬ лҒҠк№Җ мӢң л©”мӢңм§Җ мң мӢӨ. isSocketConnectedлҘј useEffectлЎң к°җмӢңн•ҳл©° PENDING/FAILED л©”мӢңм§Җ мһҗлҸҷ мһ¬м „мҶЎ"
              />
            </li>
            <li>
              мҠ¬лқјмқҙлҚ” л“ңлһҳк·ё мӨ‘ л°”н…ҖмӢңнҠё к№ңл№Ўмһ„ н•ҙкІ°: л“ңлһҳк·ё мӨ‘ лЎңм»¬ мғҒнғңл§Ң мӮ¬мҡ©, мҷ„лЈҢ лІ„нҠј мӢң л¶ҖлӘЁ
              мғҒнғң м—…лҚ°мқҙнҠё<Fn
                note="JS мҠӨл Ҳл“ңмҷҖ л„ӨмқҙнӢ°лёҢ UI мҠӨл Ҳл“ң к°„ л№„лҸҷкё° нғҖмқҙл°Қ м°Ёмқҙк°Җ лҲ„м Ғлҗҳм–ҙ л ҢлҚ”л§Ғ нғҖмқҙл°Қмқҙ м–ҙкёӢлӮҳлҠ” кІғмқҙ мӣҗмқёмңјлЎң нҢҗлӢЁ"
              />
            </li>
          </ul>
        </li>
        <li>к°ңл°ң кё°к°„ лҚ°мқјлҰ¬ мҠӨнҒ¬лҹј мЈјмөң, нҢҖ м „мӣҗ лӘ©н‘ң кіөмң  л°Ҹ мқҙмҠҲ нҢҢм•… мІҙкі„нҷ”</li>
      </ul>
    </div>
  </div>

  <!-- GOGOнҢҖ -->
  <div class="org-block">
    <div class="org-header">
      <h3 class="org-name">GOGOнҢҖ</h3>
    </div>
    <p class="org-role">Frontend Developer</p>

    <div class="proj-block">
      <div class="proj-header">
        <span class="proj-name">
          GOGO
          <ChipLink
            href="https://github.com/team-gogo/GOGO-Frontend"
            icon="bi-github"
            label="GitHub"
          />
          <ChipLink
            href="https://steady-trip-f5b.notion.site/GOGO-V3-1b220f98a3f680e4888ad58b02139d42?pvs=74"
            icon="bi-file-text"
            label="Docs"
          />
        </span>
        <DateLabel date="2025. 03. ~ 2025. 05." />
      </div>
      <p class="desc">
        м „көӯ мӨ‘В·кі л“ұн•ҷкөҗ лҢҖмғҒ мҠӨнҸ¬мё  н–үмӮ¬ н”Ңлһ«нҸј. мҲҳкё° мӢ мІӯм„ңмҷҖ л””мҠӨмҪ”л“ң мқҳмЎҙлҸ„лҘј м—Ҷм• кі , нҢҖ
        мӢ мІӯВ·лҸҷм Ғ лҢҖм§„н‘ңВ·мқјм • кҙҖлҰ¬В·мҠ№л¶Җ мҳҲмёЎмқ„ нҶөн•©.
        <Fn
          note="мҠ№л¶Җ мҳҲмёЎ мӢңмҠӨн…ңмқҖ мІӯмҶҢл…„ лҢҖмғҒ л¶ҲлІ• лҸ„л°• мӨ‘лҸ… мҳҲл°© мә нҺҳмқё мҡ”мҶҢлЎңлҸ„ кё°нҡҚ. ліёкөҗ мҡҙмҳҒ кё°к°„ лҸҷм•Ҳ 200лӘ… мқҙмғҒмқҙ мһҗл°ңм ҒмңјлЎң м°ём—¬"
        />
        <strong>ліёкөҗ мІҙмңЎлҢҖнҡҢ DAU 300+лӘ…, GA кё°мӨҖ лҲ„м Ғ мқҙлІӨнҠё 17л§Ң+кұҙ.</strong><Fn
          note="м „көӯ лӢЁмң„ нҷ•мһҘмқ„ лӘ©н‘ңлЎң нҳ„мһ¬лҸ„ л°ңм „ мӨ‘"
        />
      </p>
      <ul class="bul-list">
        <li>лҢҖнҡҢ мҡҙмҳҒ MVP н”ҢлЎңмҡ°(мҠӨн…Ңмқҙм§Җ/лҢҖм§„н‘ң/нҢҖ/л§Өм№ҳ) м„Өкі„В·кө¬нҳ„</li>
        <li>
          DnD кё°л°ҳ лҸҷм Ғ лҢҖм§„н‘ң(Bracket) кё°лҠҘ кө¬нҳ„ л°Ҹ нҢҖ мҲҳ/н„ҙ л“ұ edge case лҢҖмқ‘
          <ul class="sub-bul-list">
            <li>
              onDragEndк°Җ stale stateлҘј zustandм—җ м ҖмһҘн•ҳлҚҳ л¬ём ңлҘј, CustomEvent API мқҙлІӨнҠё лІ„мҠӨ +
              gameIdлі„ лҸ…лҰҪ кҙҖлҰ¬лЎң н•ҙкІ°<Fn
                note="onDragEnd мғқм„ұ мӢңм җмқҳ мҠӨлғ…мғ·мқҙ closureм—җ мәЎмІҳлҗҳм–ҙ лӢӨмқҢ л ҢлҚ”л§Ғк№Ңм§Җ мҳӨм—јлҗң мғҒнғңк°Җ м „нҢҢлҗҳлҠ” кІғмқҙ мӣҗмқё"
              />
              вҶ’
              <strong>л“ңлһҳк·ё мҰүмӢң мғҒнғң л°ҳмҳҒ</strong>
            </li>
            <li>
              overflow:hidden м»Ён…Ңмқҙл„Ҳк°Җ л“ңлһҳк·ё мҡ”мҶҢлҘј нҒҙлҰ¬н•‘н•ҳлҠ” л¬ём ңлҘј, React createPortalлЎң
              document.bodyм—җ л ҢлҚ”л§Ғн•ҳм—¬ н•ҙкІ°
            </li>
          </ul>
        </li>
        <li>м»Өл®ӨлӢҲнӢ° мқҙлҜём§Җ мІЁл¶Җ/мЎ°нҡҢмҲҳ н‘ңмӢң кө¬нҳ„, лҢ“кёҖ мһ…л Ҙ/м •л ¬/л°ҳмқ‘нҳ• л“ұ UX к°ңм„ </li>
      </ul>
    </div>
  </div>
</section>

<style>
  .org-block {
    margin-bottom: 2rem;
  }

  .org-header {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.5rem;
    margin-bottom: 0.125rem;
  }

  .org-name {
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--text);
  }

  .org-role {
    font-size: 0.8125rem;
    color: var(--text-faint);
    margin-bottom: 0.875rem;
  }

  .proj-block {
    margin-bottom: 1.25rem;
    padding-left: 1rem;
    border-left: 2px solid var(--border);
  }

  .proj-header {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.5rem;
    margin-bottom: 0.25rem;
  }

  .proj-name {
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--text);
  }

  .desc {
    margin: 0 0 0.625rem;
    line-height: 1.72;
    color: var(--text-soft);
  }

  .bul-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .bul-list > li {
    font-size: 0.875rem;
    color: var(--text-muted);
    line-height: 1.7;
    padding-left: 1rem;
    position: relative;
  }

  .bul-list > li::before {
    content: 'вҖў';
    position: absolute;
    left: 0;
    color: var(--text-faint);
  }

  .sub-bul-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .sub-bul-list > li {
    font-size: 0.875rem;
    color: var(--text-muted);
    line-height: 1.7;
    padding-left: 1rem;
    position: relative;
  }

  .sub-bul-list > li::before {
    content: 'вҖў';
    position: absolute;
    left: 0;
    color: var(--text-faint);
  }

  .bul-list strong,
  .sub-bul-list strong {
    font-weight: 600;
    color: var(--text);
  }
</style>
