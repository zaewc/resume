---
const driveUrl = import.meta.env.PUBLIC_PORTFOLIO_DRIVE_URL;
---

<section id="portfolio-section" class="portfolio-section">
  <p class="portfolio-sub">더 다양한 경험을 자세히 담았습니다.</p>
  <a href={driveUrl} target="_blank" rel="noopener noreferrer" class="portfolio-btn">
    포트폴리오 보러가기
    <i class="bi bi-arrow-right"></i>
  </a>
</section>

<style>
  .portfolio-section {
    margin-top: 4rem;
    padding: 2.5rem 0 6rem;
    text-align: center;
    border-top: 1px solid var(--border);
  }
  .portfolio-sub {
    font-size: 0.875rem;
    color: var(--text-muted);
    margin-bottom: 1.5rem;
  }
  .portfolio-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.65rem 1.5rem;
    border-radius: 8px;
    background: var(--accent);
    color: var(--bg);
    font-size: 0.875rem;
    font-weight: 700;
    text-decoration: none;
    transition:
      opacity 0.15s,
      transform 0.15s;
  }
  .portfolio-btn:hover {
    opacity: 0.85;
    transform: translateY(-1px);
  }
  .portfolio-btn i {
    font-size: 0.9rem;
  }
</style>
