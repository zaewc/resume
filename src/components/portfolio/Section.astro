---
interface Props {
  id: string;
  label: string;
  title: string;
  class?: string;
}

const { id, label, title, class: className } = Astro.props;
---

<section {id} class:list={['py-16 md:py-20', className]}>
  <div class="mx-auto max-w-5xl px-6">
    <div class="mb-10">
      <p class="mb-1.5 font-mono text-xs font-semibold uppercase tracking-widest text-accent">
        {label}
      </p>
      <h2 class="text-2xl font-bold text-zinc-900 dark:text-zinc-100 md:text-3xl">
        {title}
      </h2>
    </div>
    <slot />
  </div>
</section>
