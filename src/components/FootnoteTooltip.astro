---

<div id="fn-tooltip" role="tooltip" aria-hidden="true"></div>

<style>
  #fn-tooltip {
    position: fixed;
    z-index: 200;
    max-width: 260px;
    padding: 0.5rem 0.75rem;
    border-radius: 6px;
    font-size: 0.72rem;
    line-height: 1.55;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.12s ease;
    white-space: normal;
    background: var(--tt-bg);
    color: var(--tt-text);
    border: 1px solid var(--tt-border);
    box-shadow: var(--tt-shadow);
  }
</style>

<script>
  const tooltip = document.getElementById('fn-tooltip')!;
  let hideTimer: ReturnType<typeof setTimeout>;

  function showTooltip(el: HTMLElement, text: string) {
    clearTimeout(hideTimer);
    tooltip.textContent = text;
    tooltip.style.opacity = '0';
    tooltip.removeAttribute('aria-hidden');

    const rect = el.getBoundingClientRect();
    tooltip.style.left = '0px';
    tooltip.style.top = '0px';
    tooltip.style.opacity = '0';

    requestAnimationFrame(() => {
      const tw = tooltip.offsetWidth;
      const th = tooltip.offsetHeight;
      const margin = 8;

      let left = rect.left + rect.width / 2 - tw / 2;
      left = Math.max(12, Math.min(left, window.innerWidth - tw - 12));

      let top = rect.top - th - margin;
      if (top < 8) top = rect.bottom + margin;

      tooltip.style.left = `${left}px`;
      tooltip.style.top = `${top}px`;
      tooltip.style.opacity = '1';
    });
  }

  function hideTooltip() {
    hideTimer = setTimeout(() => {
      tooltip.style.opacity = '0';
      tooltip.setAttribute('aria-hidden', 'true');
    }, 80);
  }

  document.querySelectorAll('.fn').forEach((el) => {
    const htmlEl = el as HTMLElement;
    const note = htmlEl.dataset.fn ?? '';
    htmlEl.addEventListener('mouseenter', () => showTooltip(htmlEl, note));
    htmlEl.addEventListener('mouseleave', hideTooltip);
    htmlEl.addEventListener('focus', () => showTooltip(htmlEl, note));
    htmlEl.addEventListener('blur', hideTooltip);
  });
</script>
