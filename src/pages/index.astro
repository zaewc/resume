  .fn:hover { text-decoration: underline; text-underline-offset: 2px; }

  /* ─── Tooltip ─── */
  #fn-tooltip {
    position: fixed;
    z-index: 200;
    max-width: 260px;
    padding: 0.5rem 0.75rem;
    border-radius: 6px;
    font-size: 0.72rem;
    line-height: 1.55;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.12s ease;
    white-space: normal;
    background: var(--tt-bg);
    color: var(--tt-text);
    border: 1px solid var(--tt-border);
    box-shadow: var(--tt-shadow);
  }
</style>

<script>
  // ── Theme toggle ──────────────────────────────────────
  const toggle = document.getElementById('theme-toggle')!;
  toggle.addEventListener('click', () => {
    const isDark = document.documentElement.classList.toggle('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
  });

  // ── Footnote tooltip ──────────────────────────────────
  const tooltip = document.getElementById('fn-tooltip')!;
  let hideTimer: ReturnType<typeof setTimeout>;

  function showTooltip(el: HTMLElement, text: string) {
    clearTimeout(hideTimer);
    tooltip.textContent = text;
    tooltip.style.opacity = '0';
    tooltip.removeAttribute('aria-hidden');

    // 위치 계산: 각주 위에 뜨도록
    const rect = el.getBoundingClientRect();
    tooltip.style.left = '0px';
    tooltip.style.top  = '0px';
    tooltip.style.opacity = '0';

    // 잠시 후 실제 크기 계산
    requestAnimationFrame(() => {
      const tw = tooltip.offsetWidth;
      const th = tooltip.offsetHeight;
      const margin = 8;

      let left = rect.left + rect.width / 2 - tw / 2;
      // 화면 밖으로 나가지 않게
      left = Math.max(12, Math.min(left, window.innerWidth - tw - 12));

      let top = rect.top - th - margin;
      // 위쪽 공간 없으면 아래에
      if (top < 8) top = rect.bottom + margin;

      tooltip.style.left = `${left}px`;
      tooltip.style.top  = `${top}px`;
      tooltip.style.opacity = '1';
    });
  }

  function hideTooltip() {
    hideTimer = setTimeout(() => {
      tooltip.style.opacity = '0';
      tooltip.setAttribute('aria-hidden', 'true');
    }, 80);
  }

  document.querySelectorAll<HTMLElement>('.fn').forEach((el) => {
    const note = el.dataset.fn ?? '';
    el.addEventListener('mouseenter', () => showTooltip(el, note));
    el.addEventListener('mouseleave', hideTooltip);
    el.addEventListener('focus',      () => showTooltip(el, note));
    el.addEventListener('blur',       hideTooltip);
  });

</script>
