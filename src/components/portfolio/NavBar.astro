---
import { profile } from '../../data/portfolio';

const navItems = [
  { label: 'About', href: '#about' },
  { label: '프로젝트', href: '#projects' },
  { label: '사이드 / OSS', href: '#side' },
  { label: '기술', href: '#skills' },
  { label: '학력·수상', href: '#education' },
];
---

<header
  class="sticky top-0 z-50 border-b border-zinc-200 bg-zinc-50/80 backdrop-blur-md dark:border-zinc-800 dark:bg-zinc-950/80"
>
  <nav class="mx-auto flex max-w-5xl items-center justify-between px-6 py-3">
    <a
      href="#hero"
      class="font-semibold text-zinc-900 transition-colors hover:text-accent dark:text-zinc-100"
    >
      {profile.nameEn}
    </a>

    <!-- Desktop nav -->
    <ul class="hidden gap-1 md:flex">
      {
        navItems.map((item) => (
          <li>
            <a
              href={item.href}
              class="rounded-md px-3 py-1.5 text-sm text-zinc-600 transition-colors hover:bg-zinc-100 hover:text-zinc-900 dark:text-zinc-400 dark:hover:bg-zinc-800/60 dark:hover:text-zinc-100"
            >
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>

    <!-- Mobile: GitHub link -->
    <a
      href={profile.contact.githubUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="flex items-center gap-1.5 rounded-md border border-zinc-200 px-3 py-1.5 text-sm text-zinc-600 transition-colors hover:border-zinc-300 hover:text-zinc-900 dark:border-zinc-700 dark:text-zinc-400 dark:hover:border-zinc-600 dark:hover:text-zinc-100 md:hidden"
    >
      GitHub
    </a>
  </nav>
</header>
